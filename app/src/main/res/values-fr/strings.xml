    <string name="dns_desc_cloudflare">L\'un des fournisseurs DNS publics les plus rapides au monde, axé sur la confidentialité.</string>
    <string name="dns_cloudflare_default">Basique (accès rapide et confidentialité)</string>
    <string name="dns_cloudflare_malware">Blocage des logiciels malveillants</string>
    <string name="dns_cloudflare_family">Famille (blocage des logiciels malveillants + contenu pour adultes + SafeSearch)</string>
    <string name="dns_desc_opendns">L\'un des services les plus anciens et les plus fiables appartenant à Cisco.</string>
    <string name="dns_opendns_home">Basique (Accueil / pas de filtrage)</string>
    <string name="dns_opendns_family">Famille (Family Shield / filtrage préinstallé)</string>
    <string name="dns_opendns_family_desc">Adapté aux routeurs, filtre le contenu adulte sans avoir besoin de créer un compte.</string>
    <string name="dns_desc_cleanbrowsing">Un service spécialisé axé exclusivement sur le blocage des contenus indésirables.</string>
    <string name="dns_cleanbrowsing_security">Filtre de sécurité</string>
    <string name="dns_cleanbrowsing_adult">Filtre adulte</string>
    <string name="dns_cleanbrowsing_family">Filtre familial</string>
    <string name="dns_cleanbrowsing_family_desc">Bloque les proxys, les tunnels VPN, la pornographie et permet strictement une recherche sécurisée dans Google/YouTube.</string>
    <string name="dns_desc_adguard">Le meilleur choix pour ceux qui souhaitent se débarrasser de la publicité au niveau des requêtes réseau.</string>
    <string name="dns_adguard_default">Basique (bloque les publicités, les trackers et le phishing)</string>
    <string name="dns_adguard_family">Famille (contenu de base + adulte + SafeSearch)</string>
    <string name="dns_adguard_unfiltered">Sans filtrage (juste un service rapide et fiable)</string>
    <string name="dns_desc_controld">DNS moderne et très flexible des créateurs de Windscribe.</string>
    <string name="dns_controld_uncensored">Sans filtrage (Internet pur / Non censuré)</string>
    <string name="dns_controld_ads">Blocage des publicités (annonces et trackers)</string>
    <string name="dns_controld_family">Семейный (все: реклама + соцсети + контент для взрослых)</string>
    <string name="dns_desc_quad9">Service mettant l\'accent sur la cybersécurité.</string>
    <string name="dns_quad9_default">Standard (par défaut/bloque le phishing et les logiciels malveillants)</string>
    <string name="dns_quad9_ecs">Prise en charge Standard + ECS (avec prise en charge ECS)</string>
    <string name="dns_quad9_ecs_desc">Transfère une petite partie de votre adresse IP (sous-réseau client EDNS) pour un routage plus précis vers les serveurs CDN.</string>
