    <string name="dns_desc_opendns">Um dos serviços mais antigos e confiáveis ​​da Cisco.</string>
    <string name="dns_opendns_home">Básico (Home/sem filtragem)</string>
    <string name="dns_opendns_family">Família (Family Shield / filtragem pré-instalada)</string>
    <string name="dns_opendns_family_desc">Adequado para roteadores, filtra conteúdo adulto sem a necessidade de criar uma conta.</string>
    <string name="dns_desc_cleanbrowsing">Um serviço especializado focado exclusivamente no bloqueio de conteúdos indesejados.</string>
