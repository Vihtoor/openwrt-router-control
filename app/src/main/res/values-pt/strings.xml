    <string name="dns_cleanbrowsing_adult">Filtro Adulto</string>
    <string name="dns_cleanbrowsing_family">Filtro Familiar</string>
    <string name="dns_cleanbrowsing_family_desc">Bloqueia proxies, túneis VPN, pornografia e permite estritamente a pesquisa segura no Google/YouTube.</string>
    <string name="dns_desc_adguard">A melhor escolha para quem quer se livrar da publicidade no nível de solicitação da rede.</string>
