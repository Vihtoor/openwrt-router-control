    <string name="dns_adguard_family">Família (básico + conteúdo adulto + SafeSearch)</string>
    <string name="dns_adguard_unfiltered">Sem filtragem (apenas serviço rápido e confiável)</string>
    <string name="dns_desc_controld">DNS moderno e muito flexível dos criadores do Windscribe.</string>
    <string name="dns_controld_uncensored">Sem filtragem (Internet pura/Sem censura)</string>
    <string name="dns_controld_ads">Bloqueio de anúncios (anúncios e rastreadores)</string>
    <string name="dns_controld_family">Família (todos: publicidade + redes sociais + conteúdo adulto)</string>
    <string name="dns_desc_quad9">Atendimento com ênfase em segurança cibernética.</string>
    <string name="dns_quad9_default">Padrão (padrão/bloqueia phishing e malware)</string>
