    <string name="dns_desc_cloudflare">Один из самых быстрых публичных DNS-провайдеров в мире с акцентом на конфиденциальность.</string>
    <string name="dns_cloudflare_default">Базовый (быстрый доступ и приватность)</string>
    <string name="dns_cloudflare_malware">Защита от вредоносного ПО (Malware Block)</string>
    <string name="dns_cloudflare_family">Семейный (блокировка вредоносного ПО + контента для взрослых + SafeSearch)</string>
    <string name="dns_desc_opendns">Один из старейших и надежнейших сервисов, принадлежащий компании Cisco.</string>
    <string name="dns_opendns_home">Базовый (Home / без фильтрации)</string>
    <string name="dns_opendns_family">Семейный (Family Shield / предустановленная фильтрация)</string>
    <string name="dns_opendns_family_desc">Подходит для роутеров, фильтрует контент для взрослых без необходимости создания учетной записи.</string>
    <string name="dns_desc_cleanbrowsing">Специализированный сервис, ориентированный исключительно на блокировку нежелательного контента.</string>
    <string name="dns_cleanbrowsing_security">Фильтр безопасности (Security Filter)</string>
    <string name="dns_cleanbrowsing_adult">Взрослый фильтр (Adult Filter)</string>
    <string name="dns_cleanbrowsing_family">Семейный фильтр (Family Filter)</string>
    <string name="dns_cleanbrowsing_family_desc">Блокирует прокси, VPN-туннели, порнографию и жестко включает безопасный поиск в Google/YouTube.</string>
    <string name="dns_desc_adguard">Лучший выбор для тех, кто хочет избавиться от рекламы на уровне сетевых запросов.</string>
    <string name="dns_adguard_default">Базовый (блокировка рекламы, трекеров и фишинга)</string>
    <string name="dns_adguard_family">Семейный (базовый + контент для взрослых + SafeSearch)</string>
    <string name="dns_adguard_unfiltered">Нефильтрующий (просто быстрый и надежный сервис)</string>
    <string name="dns_desc_controld">Современный и очень гибкий DNS от создателей Windscribe.</string>
    <string name="dns_controld_uncensored">Нефильтрующий (чистый интернет / Uncensored)</string>
    <string name="dns_controld_ads">Блокировка рекламы (Ads &amp; Trackers)</string>
    <string name="dns_controld_family">Семейный (все: реклама + соцсети + контент для взрослых)</string>
    <string name="dns_desc_quad9">Сервис с акцентом на кибербезопасность.</string>
    <string name="dns_quad9_default">Стандартный (по умолчанию / блокировка фишинга и малвари)</string>
    <string name="dns_quad9_ecs">Стандартный + ECS-поддержка (с поддержкой ECS)</string>
    <string name="dns_quad9_ecs_desc">Передает малую часть вашего IP-адреса (EDNS Client Subnet) для более точной маршрутизации до CDN-серверов.</string>
